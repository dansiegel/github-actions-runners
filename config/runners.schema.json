{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/github-actions-runners/runners.schema.json",
  "title": "github-actions-runners configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "defaults", "runnerPools", "accounts"],
  "properties": {
    "version": { "const": 1 },
    "project": { "const": "github-actions-runners" },
    "publicVisibilityOptIn": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowPublicVisibility": { "type": "boolean" },
        "reviewedBy": { "type": "string" },
        "reviewedAt": { "type": "string" },
        "reason": { "type": "string" },
        "sharedPackageCacheRisk": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowSharedPackageCache": { "type": "boolean" },
            "reviewedBy": { "type": "string" },
            "reviewedAt": { "type": "string" },
            "reason": { "type": "string" }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "required": ["github"],
      "properties": {
        "totalRunnerCap": { "type": "integer", "minimum": 1, "default": 20 },
        "openSourceReady": { "type": "boolean", "default": true },
        "privateFirst": { "type": "boolean", "default": true },
        "sharedPackageCache": { "$ref": "#/$defs/sharedPackageCache" },
        "azure": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "subscriptionId": { "type": "string" },
            "tenantId": { "type": "string" },
            "region": { "type": "string", "default": "eastus" },
            "resourceGroup": { "type": "string" },
            "deploymentIdentity": {
              "type": "object",
              "required": ["scope", "resourceGroup"],
              "properties": {
                "scope": { "const": "resourceGroup" },
                "resourceGroup": { "type": "string" },
                "note": { "type": "string" }
              }
            }
          }
        },
        "github": {
          "type": "object",
          "required": ["tokenProvider"],
          "additionalProperties": true,
          "properties": {
            "apiBaseUrl": { "type": "string", "default": "https://api.github.com" },
            "runnerScopeDefault": { "enum": ["repository", "organization"] },
            "ephemeral": { "type": "boolean", "default": true },
            "runnerRelease": { "$ref": "#/$defs/runnerRelease" },
            "tokenProvider": { "$ref": "#/$defs/tokenProvider" }
          }
        }
      }
    },
    "runnerPools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "os", "arch"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,40}$" },
          "os": { "enum": ["linux"] },
          "arch": { "enum": ["x64", "arm64"] },
          "labels": { "type": "array", "items": { "type": "string" } },
          "minRunners": { "type": "integer", "minimum": 0, "default": 0 },
          "maxRunners": { "type": "integer", "minimum": 1 },
          "idleTimeoutMinutes": { "type": "integer", "minimum": 1 },
          "scalingMode": { "enum": ["fixed-capacity-v1"] },
          "ephemeral": { "type": "boolean", "default": true },
          "azure": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "vmSize": { "type": "string" },
              "image": { "type": "string" },
              "orchestrationMode": { "enum": ["Uniform", "Flexible"] },
              "upgradePolicyMode": { "enum": ["automatic", "manual", "rolling"] },
              "publicIp": { "type": "boolean" }
            }
          }
        }
      }
    },
    "accounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["kind", "owner", "visibility"],
        "properties": {
          "kind": { "enum": ["user", "organization"] },
          "owner": { "type": "string" },
          "visibility": { "enum": ["private", "public", "untrusted"] },
          "tokenProvider": { "$ref": "#/$defs/tokenProvider" },
          "runnerGroup": { "type": "string" },
          "repositories": {},
          "pools": { "type": "array" }
        }
      }
    }
  },
  "$defs": {
    "sharedPackageCache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "root": { "type": "string", "pattern": "^/.*" },
        "maxSizeGb": { "type": "integer", "minimum": 1 },
        "pruneAfterDays": { "type": "integer", "minimum": 1 },
        "ownership": { "type": "string", "pattern": "^[a-z_][a-z0-9_-]*:[a-z_][a-z0-9_-]*$" },
        "packageManagers": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["apt", "npm", "nuget", "pip", "cargo", "go"] }
        }
      }
    },
    "runnerRelease": {
      "type": "object",
      "required": ["version", "sha256"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "sha256": {
          "type": "object",
          "required": ["linux-x64", "linux-arm64"],
          "additionalProperties": false,
          "properties": {
            "linux-x64": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
            "linux-arm64": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
          }
        }
      }
    },
    "tokenProvider": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "vmCredentialSource": { "$ref": "#/$defs/vmCredentialSource" }
      },
      "oneOf": [
        {
          "required": ["type", "command"],
          "properties": {
            "type": { "const": "command" },
            "command": { "type": "string" },
            "vmCredentialSource": { "$ref": "#/$defs/vmCredentialSource" }
          }
        },
        { "required": ["type", "env"], "properties": { "type": { "const": "env" }, "env": { "type": "string" } } },
        { "required": ["type", "vault", "secretName"], "properties": { "type": { "const": "keyVault" }, "vault": { "type": "string" }, "secretName": { "type": "string" } } }
      ]
    },
    "vmCredentialSource": {
      "type": "object",
      "required": ["type", "keyVaultName", "appIdSecretName", "privateKeySecretName", "installationIdSecretName"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "managedIdentityGitHubApp" },
        "managedIdentityClientId": { "type": "string" },
        "keyVaultName": { "type": "string" },
        "appIdSecretName": { "type": "string" },
        "privateKeySecretName": { "type": "string" },
        "installationIdSecretName": { "type": "string" }
      }
    }
  }
}
